generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Point {
  id          String   @id
  lat         Float
  lng         Float
  name        String
  categories  Json
  rating      Float    @default(0)
  description String   @default("")
  contact     String   @default("")
  keywords    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([updatedAt])
}
